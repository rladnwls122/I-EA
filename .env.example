# --- Database (MySQL / TiDB) ---
# 로컬 Docker 예시: mysql://user:password@localhost:3306/qidea
DATABASE_URL="mysql://user:password@localhost:3306/qidea"

# --- Redis (BullMQ) ---
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=""
# Aiven 등 관리형 Redis(TLS)만 true. 로컬/Railway는 비워둠.
REDIS_TLS=""

# --- Auth ---
JWT_SECRET="change-me"

# --- LLM (AI 문항 생성, Gemini) ---
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_MAX_TOKENS="4096"

# --- 서버 ---
PORT="3000"
