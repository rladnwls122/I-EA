# =====================================================================
# Q-Idea API 환경변수 양식
#   cp .env.example .env  후 값을 채운다. .env는 .gitignore 대상이다.
#   주석의 "기본값"은 값이 없을 때 코드가 실제로 쓰는 fallback이다.
# =====================================================================

# --- Database (MySQL / TiDB) --- [필수]
# 없으면 prisma validate/generate와 부팅이 모두 실패한다.
# 로컬 Docker 예시: mysql://user:password@localhost:3306/qidea
DATABASE_URL="mysql://user:password@localhost:3306/qidea"

# --- Redis (BullMQ) ---
# AI 문항 생성이 비동기 큐라, Redis가 없으면 생성 잡이 처리되지 않는다.
REDIS_HOST="127.0.0.1"                  # 기본값: 127.0.0.1
REDIS_PORT="6379"                       # 기본값: 6379
REDIS_PASSWORD=""                       # 없으면 비워둔다
# Aiven 등 관리형 Redis(TLS)만 "true". 로컬/Railway는 비워둔다.
REDIS_TLS=""

# --- Auth --- [필수]
# 운영에서 반드시 교체한다. 기본값을 두면 토큰 위조가 가능하다.
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"                     # 기본값: 7d

# --- LLM (Gemini) ---
# 키가 없어도 부팅은 되지만, 생성 잡이 FAILED로 떨어진다.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"         # 기본값: gemini-2.5-flash
GEMINI_MAX_TOKENS="4096"                # 기본값: 4096
# 비워두면 https://generativelanguage.googleapis.com/v1beta 사용
GEMINI_BASE_URL=""

# --- 서버 ---
# 주의: Next.js 프론트(web/)도 3000을 쓴다. 동시 실행 시 하나를 바꿔야 한다.
PORT="3000"                             # 기본값: 3000
